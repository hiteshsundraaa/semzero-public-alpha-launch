# ── Required ──────────────────────────────────────────────────────────────────
# SQLAlchemy URL for your database
# SQLite (dev):     SEMZERO_DB_URL=sqlite:///data/mydb.db
# Postgres (prod):  SEMZERO_DB_URL=postgresql://user:password@host:5432/dbname
# Snowflake:        SEMZERO_DB_URL=snowflake://user:password@account/database/schema
# Databricks:       SEMZERO_DB_URL=databricks://token:<token>@<server-hostname>?http_path=/sql/1.0/endpoints/<warehouse>&catalog=main&schema=analytics
SEMZERO_DB_URL=sqlite:///data/graph_store.db

# ── GitHub (Change Gate PR posting) ──────────────────────────────────────────
SEMZERO_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
SEMZERO_GITHUB_REPO=your-org/your-repo

# ── Slack (alerts) ────────────────────────────────────────────────────────────
SEMZERO_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Snowflake (if not using db_url) ──────────────────────────────────────────
# SEMZERO_SF_ACCOUNT=myaccount.us-east-1
# SEMZERO_SF_USER=myuser
# SEMZERO_SF_PASSWORD=mypassword
# SEMZERO_SF_DATABASE=PROD
# SEMZERO_SF_SCHEMA=PUBLIC
# SEMZERO_SF_WAREHOUSE=COMPUTE_WH

# ── Databricks (if not using db_url) ─────────────────────────────────────────
# SEMZERO_DBX_SERVER_HOSTNAME=dbc-12345.cloud.databricks.com
# SEMZERO_DBX_HTTP_PATH=/sql/1.0/endpoints/1234567890abcdef
# SEMZERO_DBX_TOKEN=dapi...
# SEMZERO_DBX_CATALOG=main
# SEMZERO_DBX_SCHEMA=analytics
# SEMZERO_DBX_CLONE_CATALOG=semzero_scratch
